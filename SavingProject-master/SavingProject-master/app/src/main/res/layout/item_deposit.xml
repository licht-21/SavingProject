<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_item"
    android:layout_marginVertical="@dimen/spacing_item"
    app:cardBackgroundColor="@color/app_card_background"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="@dimen/elevation_card"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/deposit_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_circle"
            android:contentDescription="@null"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_add"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/brand_blue_light" />

        <TextView
            android:id="@+id/deposit_amount_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/app_text_primary"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/deposit_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/deposit_date_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/app_text_secondary"
            app:layout_constraintStart_toStartOf="@id/deposit_amount_text"
            app:layout_constraintTop_toBottomOf="@id/deposit_amount_text" />

        <TextView
            android:id="@+id/deposit_note_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/app_text_secondary"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/deposit_amount_text"
            app:layout_constraintTop_toBottomOf="@id/deposit_date_text" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_card"
    android:layout_marginVertical="@dimen/spacing_item"
    app:cardBackgroundColor="@color/app_card_background"
    app:cardCornerRadius="@dimen/radius_card"
    app:cardElevation="@dimen/elevation_card"
    app:strokeColor="@color/brand_blue_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_goal_card_inner"
        android:orientation="vertical"
        android:padding="18dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/goal_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/goal_percent"
                android:text="Goal Name"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/app_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/goal_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_toStartOf="@id/goal_menu_button"
                android:text="0%"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/brand_blue_light"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/goal_menu_button"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/goal_options"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@color/brand_gold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/goal_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 0"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/app_text_secondary" />

            <TextView
                android:id="@+id/goal_overdue_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_overdue_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="@string/overdue"
                android:textColor="@color/overdue_red"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/goal_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/app_text_secondary"
            android:visibility="gone" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/goal_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:progress="0"
            app:indicatorColor="@color/brand_blue_dark"
            app:trackColor="@color/progress_track"
            app:trackCornerRadius="6dp"
            app:trackThickness="8dp" />

        <TextView
            android:id="@+id/goal_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/tap_to_add_deposit"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="@color/brand_blue_light"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

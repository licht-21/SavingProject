<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SavingProject" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/brand_blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_blue_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/brand_gold</item>
        
        <!-- Background and surface -->
        <item name="android:windowBackground">@color/app_background</item>
        <item name="colorSurface">@color/app_surface</item>
        <item name="colorOnSurface">@color/app_text_primary</item>
        <item name="colorSurfaceVariant">@color/app_card_background</item>
        <item name="colorOnSurfaceVariant">@color/app_text_secondary</item>
        
        <!-- Status and Navigation Bars -->
        <item name="android:statusBarColor">@color/brand_cream</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bottom_nav_bg</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.SavingProject" parent="Base.Theme.SavingProject" />
</resources>
<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.SavingProject.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/app_text_primary</item>
    </style>

    <style name="TextAppearance.SavingProject.ScreenTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/app_text_primary</item>
    </style>

    <style name="TextAppearance.SavingProject.ScreenSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/app_text_secondary</item>
    </style>

    <style name="TextAppearance.SavingProject.SectionLabel" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.SavingProject.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/app_background</item>
        <item name="navigationIconTint">@color/app_text_primary</item>
    </style>

    <style name="Widget.SavingProject.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="backgroundTint">@color/brand_blue_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/radius_button</item>
    </style>

    <style name="Widget.SavingProject.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_stroke</item>
        <item name="android:textColor">@color/brand_blue_dark</item>
        <item name="cornerRadius">@dimen/radius_button</item>
    </style>

    <style name="Widget.SavingProject.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/brand_blue_dark</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.SavingProject.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="hintTextColor">@color/input_hint_color</item>
        <item name="startIconTint">@color/brand_gold</item>
        <item name="endIconTint">@color/brand_gold</item>
    </style>

    <style name="Widget.SavingProject.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/app_card_background</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.SavingProject.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@drawable/bg_bottom_nav</item>
        <item name="elevation">@dimen/elevation_bottom_nav</item>
        <item name="itemIconTint">@color/bottom_nav_icon_color</item>
        <item name="itemTextColor">@color/bottom_nav_text_color</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.SavingProject.BottomNav.ActiveIndicator</item>
    </style>

    <style name="Widget.SavingProject.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/brand_blue_soft</item>
    </style>

    <style name="Widget.SavingProject.Fab" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/brand_blue_dark</item>
        <item name="tint">@color/white</item>
        <item name="elevation">@dimen/elevation_fab</item>
    </style>

</resources>

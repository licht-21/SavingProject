<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#E8E5DA"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="#304C89"
            app:title=""
            app:titleCentered="true">

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/new_savings_goal"
                android:textColor="#304C89"
                android:textStyle="bold"
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/goal_name_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/goal_name_hint"
                app:boxStrokeColor="#5070B7"
                app:hintTextColor="#5070B7"
                app:startIconDrawable="@android:drawable/ic_menu_edit"
                app:startIconTint="#648DE5">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/goal_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:textColor="#304C89" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/target_amount_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/target_amount_hint"
                app:boxStrokeColor="#5070B7"
                app:hintTextColor="#5070B7"
                app:prefixText="₱"
                app:startIconDrawable="@android:drawable/ic_menu_save"
                app:startIconTint="#648DE5">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/target_amount_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="#304C89" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/starting_amount_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/starting_amount_hint"
                app:boxStrokeColor="#5070B7"
                app:hintTextColor="#5070B7"
                app:prefixText="₱"
                app:startIconDrawable="@android:drawable/ic_menu_add"
                app:startIconTint="#648DE5">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/starting_amount_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="#304C89" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/due_date_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:hint="@string/due_date_hint"
                app:boxStrokeColor="#5070B7"
                app:hintTextColor="#5070B7"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
                app:endIconTint="#648DE5"
                app:startIconDrawable="@android:drawable/ic_menu_today"
                app:startIconTint="#648DE5">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/due_date_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="date"
                    android:textColor="#304C89" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_goal_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/save_goal"
                android:textColor="@android:color/white"
                app:backgroundTint="#304C89"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
